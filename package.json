{
  "name": "mcp-gateway-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo root for @swarmclawai/mcp-core and @swarmclawai/mcp-gateway.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "dev": "pnpm --filter @swarmclawai/mcp-gateway run dev",
    "bench": "tsx scripts/benchmark.ts",
    "sync-docs": "node scripts/sync-docs.mjs"
  },
  "devDependencies": {
    "@swarmclawai/mcp-core": "workspace:^",
    "@types/node": "^20.12.12",
    "tsup": "^8.1.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
